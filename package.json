{
  "name": "@vauxr/openclaw",
  "version": "0.1.0",
  "description": "An OpenClaw plugin that gives your agents the ability to speak through and control Vauxr voice assistant devices.",
  "license": "MIT",
  "type": "module",
  "main": "./index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vauxr-ai/vauxr-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/vauxr-ai/vauxr-openclaw/issues"
  },
  "homepage": "https://github.com/vauxr-ai/vauxr-openclaw#readme",
  "openclaw": {
    "extensions": [
      "./index.ts",
      "./setup-entry.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.2",
      "minGatewayVersion": "2026.4.2"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "openclaw": "^2026.4.2",
    "typescript": "^5.0.0"
  }
}
